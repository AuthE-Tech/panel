# Colors for output - RED THEME
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# --- UI HELPERS ---
print_header_rule() { echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"; }
print_status() { echo -e "${YELLOW}⏳ $1...${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }

authe_banner() {
cat <<'EOF'
    _         _   _     _____ 
   / \  _   _| |_| |__ | ____|
  / _ \| | | | __| '_ \|  _|  
 / ___ \ |_| | |_| | | | |___ 
/_/   \_\__,_|\__|_| |_|_____|
EOF
    echo -e "${RED}       Developed by @AuthEStudio & @JishnuTech69${NC}"
}

# ====================================================
# 1. PANEL MANAGEMENT
# ====================================================
panel_manager() {
    while true; do
        clear
        print_header_rule
        authe_banner
        echo -e "${RED}           🚀 PANEL CONTROL CENTER               ${NC}"
        print_header_rule
        echo -e "${WHITE}  1)${NC} ${RED}Install AuthE Panel${NC}"
        echo -e "${WHITE}  2)${NC} ${RED}Create Panel Admin User${NC}"
        echo -e "${WHITE}  3)${NC} ${RED}Update Panel${NC}"
        echo -e "${WHITE}  0)${NC} ${RED}Back${NC}"
        print_header_rule
        read -p "Select Option → " pchoice

        case $pchoice in
            1) 
                print_status "Launching AuthE Panel Installer"
                bash <(curl -s https://raw.githubusercontent.com/nobita329/The-Coding-Hub/refs/heads/main/srv/panel/pterodactyl.sh)
                ;;
            2) 
                if [ ! -d /var/www/pterodactyl ]; then
                    print_error "Panel not installed!"
                else
                    cd /var/www/pterodactyl && php artisan p:user:make
                fi
                ;;
            3) 
                print_status "Updating AuthE Panel"
                cd /var/www/pterodactyl || { print_error "Not found"; break; }
                php artisan down
                curl -L https://github.com/pterodactyl/panel/releases/download/v1.11.11/panel.tar.gz | tar -xzv
                chmod -R 755 storage/* bootstrap/cache
                composer install --no-dev --optimize-autoloader
                php artisan view:clear && php artisan config:clear
                php artisan migrate --seed --force
                chown -R www-data:www-data /var/www/pterodactyl/*
                php artisan queue:restart && php artisan up
                print_success "Update finished"
                ;;
            0) return 0 ;;
        esac
        read -p "Press Enter to continue..."
    done
}

# ====================================================
# 2. WINGS MANAGEMENT
# ====================================================
wings_manager() {
    clear
    print_header_rule
    authe_banner
    echo -e "${RED}           🦅 WINGS INSTALLER (AuthE)${NC}"
    print_header_rule

    print_status "Installing Docker"
    curl -sSL https://get.docker.com/ | CHANNEL=stable bash
    systemctl enable --now docker

    print_status "Downloading AuthE Wings"
    ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')
    mkdir -p /etc/pterodactyl
    curl -L -o /usr/local/bin/wings "https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_$ARCH"
    chmod u+x /usr/local/bin/wings

    print_status "Configuring System Service"
    tee /etc/systemd/system/wings.service <<EOF > /dev/null
[Unit]
Description=AuthE Wings Daemon
After=docker.service
[Service]
User=root
WorkingDirectory=/etc/pterodactyl
ExecStart=/usr/local/bin/wings
Restart=on-failure
[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload && systemctl enable wings

    print_status "Generating AuthE SSL"
    mkdir -p /etc/certs/authe
    openssl req -new -newkey rsa:4096 -days 3650 -nodes -x509 \
    -subj "/C=NA/ST=NA/L=NA/O=AuthEStudio/CN=AuthE SSL" \
    -keyout /etc/certs/authe/privkey.pem -out /etc/certs/authe/fullchain.pem > /dev/null 2>&1

    # Create Helper Command
    tee /usr/local/bin/authe-wing <<'EOF' > /dev/null
#!/bin/bash
echo -e "\033[1;31m🦅 AuthE Wings Helper\033[0m"
echo -e "Developed by @JishnuTech69"
echo -e "Start:   sudo systemctl start wings"
echo -e "Status:  sudo systemctl status wings"
echo -e "Logs:    sudo journalctl -u wings -f"
EOF
    chmod +x /usr/local/bin/authe-wing

    print_success "Wings installed! Use 'authe-wing' for commands."
    read -p "Press Enter to continue..."
}

# ====================================================
# 3. UNINSTALLER
# ====================================================
uninstaller_manager() {
    clear
    print_header_rule
    authe_banner
    echo -e "${RED}           🗑️ AUTHE CLEANUP TOOL${NC}"
    print_header_rule
    echo -e "1) Uninstall Panel Only"
    echo -e "2) Uninstall Wings Only"
    echo -e "3) Wipe Everything"
    echo -e "0) Back"
    read -p "Choice: " uchoice

    case $uchoice in
        1|3)
            print_status "Removing Panel"
            systemctl stop pteroq 2>/dev/null
            rm -rf /var/www/pterodactyl
            mysql -u root -e "DROP DATABASE IF EXISTS panel; DROP USER IF EXISTS 'pterodactyl'@'127.0.0.1';"
            rm -f /etc/nginx/sites-enabled/pterodactyl.conf
            print_success "Panel data wiped."
            ;;
    esac
    case $uchoice in
        2|3)
            print_status "Removing Wings"
            systemctl stop wings 2>/dev/null
            rm -rf /etc/pterodactyl /var/lib/pterodactyl /usr/local/bin/wings
            print_success "Wings data wiped."
            ;;
    esac
    read -p "Cleanup complete. Enter to return..."
}

# ====================================================
# 4. SYSTEM INFO
# ====================================================
system_info() {
    print_header_rule
    echo -e "${WHITE} Hostname: $(hostname)"
    echo -e " OS:       $(uname -srm)"
    echo -e " Uptime:   $(uptime -p)"
    echo -e " Memory:   $(free -h | awk '/Mem:/ {print $3"/"$2}')"
    print_header_rule
    read -p "Press Enter to return..."
}

# ====================================================
# MAIN INTERFACE
# ====================================================
show_menu() {
    clear
    print_header_rule
    authe_banner
    print_header_rule
    echo -e "${WHITE}${BOLD}  1)${NC} ${RED}Panel Installation / Management${NC}"
    echo -e "${WHITE}${BOLD}  2)${NC} ${RED}Wings Installation / Helper${NC}"
    echo -e "${WHITE}${BOLD}  3)${NC} ${RED}Uninstaller / Cleanup${NC}"
    echo -e "${WHITE}${BOLD}  4)${NC} ${RED}System Information${NC}"
    echo -e "${WHITE}${BOLD}  0)${NC} ${RED}Exit${NC}"
    print_header_rule
    echo -ne "${YELLOW}📝 Select an option [0-4]: ${NC}"
}

# --- THE START COMMANDS ---
# This is what makes the script actually run!
clear
authe_banner
sleep 1.5

while true; do
    show_menu
    read -r choice
    case $choice in
        1) panel_manager ;;
        2) wings_manager ;;
        3) uninstaller_manager ;;
        4) system_info ;;
        0) 
            echo -e "${GREEN}Exiting AuthE Studio Manager...${NC}"
            exit 0 ;;
        *) 
            echo -e "${RED}Invalid option!${NC}"
            sleep 1 ;;
    esac
done
