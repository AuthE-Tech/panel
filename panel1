# Colors - RED & WHITE THEME
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m'

# --- UI HELPERS ---
print_header() {
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${WHITE}  $1 ${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

authe_banner() {
    clear
cat <<'EOF'
    _         _   _     _____ 
   / \  _   _| |_| |__ | ____|
  / _ \| | | | __| '_ \|  _|  
 / ___ \ |_| | |_| | | | |___ 
/_/   \_\__,_|\__|_| |_|_____|
EOF
    echo -e "${RED}      Developed By: AuthETech | Powered By: AuthEStudio${NC}"
}

# --- 1. CORE INSTALLER ---
install_panel() {
    authe_banner
    print_header "INSTALLING PTERODACTYL PANEL"
    
    echo -e "${YELLOW}⏳ Installing Dependencies (PHP 8.3, Nginx, MariaDB)...${NC}"
    apt update -y && apt install -y software-properties-common curl ca-certificates gnupg2 sudo
    add-apt-repository ppa:ondrej/php -y && apt update -y
    apt install -y php8.3 php8.3-{common,cli,gd,mysql,mbstring,bcmath,xml,fpm,curl,zip} nginx mariadb-server redis-server tar unzip git

    echo -e "${YELLOW}⏳ Configuring Database...${NC}"
    DB_PASS=$(openssl rand -hex 12)
    mysql -u root <<EOF
CREATE DATABASE IF NOT EXISTS panel;
CREATE USER IF NOT EXISTS 'pterodactyl'@'127.0.0.1' IDENTIFIED BY '$DB_PASS';
GRANT ALL PRIVILEGES ON panel.* TO 'pterodactyl'@'127.0.0.1' WITH GRANT OPTION;
FLUSH PRIVILEGES;
EOF

    echo -e "${YELLOW}⏳ Downloading Files...${NC}"
    mkdir -p /var/www/pterodactyl && cd /var/www/pterodactyl
    curl -Lo panel.tar.gz https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz
    tar -xzvf panel.tar.gz && chmod -R 755 storage/* bootstrap/cache
    
    curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer
    composer install --no-dev --optimize-autoloader
    cp .env.example .env && php artisan key:generate --force

    print_header "DATABASE INFO - SAVE THIS"
    echo -e "DB User: pterodactyl | DB Pass: $DB_PASS"
    print_header "FOLLOW ON-SCREEN PROMPTS"
    
    php artisan p:environment:setup
    php artisan p:environment:database --host=127.0.0.1 --port=3306 --database=panel --username=pterodactyl --password=$DB_PASS
    php artisan migrate --seed --force
    php artisan p:user:make
    chown -R www-data:www-data /var/www/pterodactyl/*
    echo -e "${GREEN}✅ Panel Installation Complete!${NC}"
}

# --- 2. THEMES & EXTENSIONS ---
theme_manager() {
    authe_banner
    print_header "AUTHE THEME & EXTENSION CENTER"
    echo -e "${WHITE}1) Install Blueprint Framework${NC}"
    echo -e "${WHITE}2) Install AuthE Custom Theme${NC}"
    echo -e "${WHITE}3) Install Minecraft Server Manager Extension${NC}"
    echo -e "${WHITE}0) Back${NC}"
    read -p "Select choice: " tchoice

    case $tchoice in
        1)
            echo -e "${YELLOW}⏳ Installing Blueprint...${NC}"
            cd /var/www/pterodactyl
            wget "$(curl -s https://api.github.com/repos/BlueprintFramework/framework/releases/latest | grep 'browser_download_url' | grep 'release.zip' | cut -d '"' -f 4)" -O release.zip
            unzip release.zip && bash blueprint.sh
            ;;
        2)
            echo -e "${YELLOW}⏳ Applying AuthE Custom Theme...${NC}"
            # Logic for theme curl
            bash <(curl -s https://raw.githubusercontent.com/nobita329/The-Coding-Hub/refs/heads/main/srv/thame/chang.sh)
            ;;
        0) return ;;
    esac
}

# --- 3. WINGS INSTALLER ---
install_wings() {
    authe_banner
    print_header "INSTALLING WINGS"
    curl -sSL https://get.docker.com/ | CHANNEL=stable bash
    systemctl enable --now docker
    mkdir -p /etc/pterodactyl
    ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')
    curl -L -o /usr/local/bin/wings "https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_$ARCH"
    chmod u+x /usr/local/bin/wings
    echo -e "${GREEN}✅ Wings Binary Installed!${NC}"
}

# --- MAIN MENU ---
while true; do
    authe_banner
    print_header "MAIN MENU"
    echo -e "${WHITE}1) Install Pterodactyl Panel${NC}"
    echo -e "${WHITE}2) Install Wings${NC}"
    echo -e "${WHITE}3) Themes & Extensions${NC}"
    echo -e "${WHITE}4) Create Admin User${NC}"
    echo -e "${WHITE}0) Exit${NC}"
    print_header "Select an option"
    read -p "→ " mainchoice

    case $mainchoice in
        1) install_panel ;;
        2) install_wings ;;
        3) theme_manager ;;
        4) cd /var/www/pterodactyl && php artisan p:user:make ;;
        0) exit 0 ;;
        *) echo -e "${RED}Invalid Option!${NC}" && sleep 1 ;;
    esac
    read -p "Press Enter to continue..."
done
